# TMDB API Configuration
# Get your free API key from: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_api_key_here

# Optional: Dataset path (default: ml-100k)
DATASET_PATH=ml-100k

# Optional: Model parameters (default: 20)
MODEL_NEIGHBORS=20

# Optional: Minimum rating count for movies (default: 5)
MIN_RATING_COUNT=5
